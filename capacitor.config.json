{
  "appId": "com.tiegames.evolrace",
  "appName": "Evolrace",
  "webDir": "www",
  "bundledWebRuntime": false,
  "android": {
    "allowMixedContent": false,
    "captureInput": true,
    "webContentsDebuggingEnabled": false
  },
  "plugins": {
    "AdMob": {
      "appId": "ca-app-pub-4166550433924758~8711390844"
    },
    "SplashScreen": {
      "launchShowDuration": 1500,
      "backgroundColor": "#000000",
      "androidSplashResourceName": "splash",
      "androidScaleType": "CENTER_CROP",
      "showSpinner": false
    }
  },
  "server": {
    "androidScheme": "https"
  }
}
